    "    'grid.alpha':       0.5,\n",
    "    'font.family':      'DejaVu Sans',\n",
    "    'axes.spines.top':  False,\n",
    "    'axes.spines.right':False,\n",
    "})\n",
    "\n",
    "# Load the CSV\n",
    "df = pd.read_csv('results.csv')\n",
    "df.head()"
   ]
